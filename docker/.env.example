# ── Proveedor LLM: "claude" | "openai" | "ollama" ─────────────────────────────
LLM_PROVIDER=ollama

# ── Anthropic (si LLM_PROVIDER=claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (si LLM_PROVIDER=openai) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Sentry ─────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=tekton-as
SENTRY_PROJECT=php-laravel
SENTRY_REGION=https://us.sentry.io

# ── JIRA / Atlassian ──────────────────────────────────────────────────────────
JIRA_BASE_URL=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=ATATT...

# ── Ollama ─────────────────────────────────────────────────────────────────────
# Modelo base (se descarga al iniciar el contenedor)
OLLAMA_MODEL=llama3.2

# Modelos separados para tareas rápidas vs. análisis complejo (opcional)
# Si no se definen, ambos usan OLLAMA_MODEL
OLLAMA_MODEL_FAST=llama3.2       # tareas de monitoreo/dedup (haiku)
OLLAMA_MODEL_FULL=llama3.1:8b    # análisis de errores complejo (sonnet)

# Host de Ollama (dentro del contenedor siempre es localhost)
OLLAMA_HOST=http://localhost:11434

# ── Workflow ───────────────────────────────────────────────────────────────────
# Poner "true" para que el workflow se ejecute automáticamente al hacer docker compose up
RUN_WORKFLOW=false
