# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Sentry ─────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=tekton-as
SENTRY_PROJECT=php-laravel
SENTRY_REGION=https://us.sentry.io

# ── JIRA / Atlassian ──────────────────────────────────────────────────────────
JIRA_BASE_URL=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=ATATT...

# ── Ollama ─────────────────────────────────────────────────────────────────────
# Modelo a descargar al iniciar: llama3.2, mistral, codellama, phi3
OLLAMA_MODEL=llama3.2

# ── Workflow ───────────────────────────────────────────────────────────────────
# Poner "true" para que el workflow se ejecute automáticamente al hacer docker compose up
RUN_WORKFLOW=false
